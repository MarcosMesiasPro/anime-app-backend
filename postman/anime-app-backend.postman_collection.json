                  "});",
                  "var json = pm.response.json();",
                  "if (json.favorite && json.favorite._id) pm.collectionVariables.set('favoriteId', json.favorite._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
